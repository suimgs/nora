        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(nora_http_requests_total{registry=~\"$registry\"}[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
