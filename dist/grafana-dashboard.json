{
  "id": null,
  "uid": "nora-overview",
  "title": "NORA — Artifact Registry",
  "description": "Overview dashboard for NORA artifact registry — HTTP traffic, cache, upstream, storage, security",
  "tags": [
    "nora",
    "registry",
    "prometheus"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "P4169E866C3094E38"
        },
        "definition": "label_values(nora_http_requests_total{registry!~\"other|ui\"}, registry)",
        "name": "registry",
        "label": "Registry",
        "type": "query",
        "includeAll": true,
        "multi": true,
        "allValue": "npm|pypi|cargo|go|docker|maven|raw|gems|terraform|ansible|nuget|pub|conan",
        "refresh": 2,
        "sort": 1,
        "regex": "/^(?!other$|ui$).*/"
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
