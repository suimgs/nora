# NORA configuration — environment variables
# Copy to /etc/nora/nora.env and adjust

# Server
NORA_HOST=0.0.0.0
NORA_PORT=4000
# Public URL — REQUIRED when behind reverse proxy (Caddy/Traefik/Nginx).
# Used to generate correct download URLs for pip, npm, cargo, etc.
# NORA_PUBLIC_URL=https://registry.example.com

# Storage
NORA_STORAGE_PATH=/var/lib/nora
# NORA_STORAGE_MODE=s3            # local | s3 | gcs
# NORA_STORAGE_S3_URL=http://s3.example.com:9000
# NORA_STORAGE_BUCKET=registry
# GCS mode: bucket from NORA_STORAGE_BUCKET; credentials from (in order)
# NORA_STORAGE_GCS_SERVICE_ACCOUNT_PATH, GOOGLE_* env, instance metadata
# (GKE Workload Identity / GCE service account — no key material needed).
# NORA_STORAGE_GCS_SERVICE_ACCOUNT_PATH=/etc/nora/gcs-sa.json
# NORA_STORAGE_GCS_BASE_URL=  # emulator / Private Google Access endpoint
# GCS mode: bucket from NORA_STORAGE_BUCKET; credentials from (in order)
# NORA_STORAGE_GCS_SERVICE_ACCOUNT_PATH, GOOGLE_* env, instance metadata
# (GKE Workload Identity / GCE service account — no key material needed).
# NORA_STORAGE_GCS_SERVICE_ACCOUNT_PATH=/etc/nora/gcs-sa.json
# NORA_STORAGE_GCS_BASE_URL=  # emulator / Private Google Access endpoint

# Auth (optional)
# NORA_AUTH_ENABLED=true
# NORA_AUTH_HTPASSWD_FILE=/etc/nora/users.htpasswd
# Token storage MUST be an absolute path inside the service's writable paths.
# ProtectSystem=strict only allows writes under /var/lib/nora; the built-in
# default (data/tokens) is relative and resolves to /etc/nora/data/tokens,
# which is read-only under systemd, so token creation fails (#816).
NORA_AUTH_TOKEN_STORAGE=/var/lib/nora/tokens

# Rate limiting
# NORA_RATE_LIMIT_ENABLED=true

# Registry selection (comma-separated list; overrides per-registry ENABLED flags)
# NORA_REGISTRIES_ENABLE=docker,npm,maven,pypi,cargo,go,raw,gems,terraform,ansible,nuget,pub,conan,rpm,deb

# Docker proxy
# NORA_DOCKER_PROXIES=https://registry-1.docker.io

# npm proxy
# NORA_NPM_PROXY=https://registry.npmjs.org
# NORA_NPM_METADATA_TTL=300

# PyPI proxy
# NORA_PYPI_PROXY=https://pypi.org/simple/

# Maven proxy
# NORA_MAVEN_PROXIES=https://repo1.maven.org/maven2

# Go proxy
# NORA_GO_PROXY=https://proxy.golang.org

# Raw
# NORA_RAW_CACHE_CONTROL=no-cache

# Cargo proxy
# NORA_CARGO_PROXY=https://index.crates.io

# RubyGems proxy
# NORA_GEMS_PROXY=https://rubygems.org
# NORA_GEMS_METADATA_TTL=300

# Terraform proxy
# NORA_TF_PROXY=https://registry.terraform.io
# NORA_TF_METADATA_TTL=300

# Ansible Galaxy proxy
# NORA_ANSIBLE_PROXY=https://galaxy.ansible.com

# NuGet proxy
# NORA_NUGET_PROXY=https://api.nuget.org/v3/index.json
# NORA_NUGET_METADATA_TTL=300

# Conan proxy
# NORA_CONAN_PROXY=https://center2.conan.io
# NORA_CONAN_METADATA_TTL=300

# Pub (Dart) proxy
# NORA_PUB_PROXY=https://pub.dev

# RPM (yum/dnf) hosted repositories — no upstream proxy; repodata is unsigned (gpgcheck=0)
# NORA_RPM_ENABLED=true
# NORA_RPM_MAX_FILE_SIZE=1073741824
# NORA_RPM_CHANGELOG_LIMIT=10
# Debian/APT hosted repositories — no upstream proxy; indexes are unsigned ([trusted=yes])
# NORA_DEB_ENABLED=true
# NORA_DEB_MAX_FILE_SIZE=1073741824

# Repository index signing (rpm/deb) — on by default; key auto-generated under
# the storage path for local storage. S3 storage requires an explicit key path.
# NORA_SIGNING_ENABLED=true
# NORA_SIGNING_KEY_PATH=/data/.signing/nora.key

# Metadata cache TTL semantics (applies to all *_METADATA_TTL vars):
#   -1 = cache forever (never refetch from upstream)
#    0 = always refetch (disable metadata cache)
#   >0 = TTL in seconds (default: 300 = 5 min)

# Curation (optional)
# NORA_CURATION_MODE=enforce
# NORA_CURATION_BLOCKLIST_FILE=/etc/nora/blocklist.json
